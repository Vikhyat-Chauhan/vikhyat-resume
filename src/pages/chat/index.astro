---
import ChatLayout from '@/layouts/ChatLayout.astro'
import ChatWidget from '@/components/chat/ChatWidget'

const meta = {
	title: 'Chat — Vikhyat Chauhan',
	description: 'Ask questions about my research, projects, and experience using RAG-powered AI.'
}
---

<ChatLayout meta={meta}>
	<section class='flex min-h-0 flex-1 flex-col'>
		<div class='mb-6 flex-shrink-0 border-b border-border pb-4'>
			<div class='flex items-baseline justify-between gap-x-4'>
				<div class='flex flex-col gap-y-1'>
					<span class='font-mono text-[0.7rem] uppercase tracking-[0.22em] text-muted-foreground'>
						/ Chat — RAG over my work
					</span>
					<h1 class='text-2xl font-semibold tracking-tight sm:text-3xl'>Ask me anything</h1>
				</div>
				<a href='/' class='font-mono text-[0.7rem] uppercase tracking-[0.18em] text-muted-foreground transition-colors hover:text-accent'>
					← Back
				</a>
			</div>
		</div>
		<ChatWidget client:load />
	</section>
</ChatLayout>
