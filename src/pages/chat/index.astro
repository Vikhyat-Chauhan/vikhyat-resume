---
import BaseLayout from '@/layouts/BaseLayout.astro'
import ChatWidget from '@/components/chat/ChatWidget'

const meta = {
	title: 'Chat — Vikhyat Chauhan',
	description: 'Ask questions about my research, projects, and experience using RAG-powered AI.'
}
---

<BaseLayout meta={meta}>
	<section class='w-full flex-1 flex flex-col'>
		<div class='mb-6'>
			<h1 class='text-2xl font-semibold'>Ask me anything</h1>
			<p class='text-sm text-muted-foreground mt-1'>
				RAG-powered chat over my research papers, projects, and resume
			</p>
		</div>
		<ChatWidget client:load />
	</section>
</BaseLayout>
