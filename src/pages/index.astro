<script>
	const buttons = document.querySelectorAll('.tab-btn')
	const panels = document.querySelectorAll('.tab-panel')
	const hero = document.getElementById('hero') as HTMLElement

	let isCollapsed = false
	let naturalHeight = hero.scrollHeight

	function collapseHero() {
		if (isCollapsed) return
		naturalHeight = hero.scrollHeight
		hero.style.height = naturalHeight + 'px'
		void hero.offsetHeight
		hero.style.height = '0'
		isCollapsed = true
	}

	function expandHero() {
		if (!isCollapsed) return
		hero.style.height = naturalHeight + 'px'
		isCollapsed = false
		const onEnd = (e: TransitionEvent) => {
			if (e.propertyName !== 'height') return
			if (!isCollapsed) hero.style.height = ''
			hero.removeEventListener('transitionend', onEnd)
		}
		hero.addEventListener('transitionend', onEnd)
	}

	// Tab switching
	buttons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const tab = btn.getAttribute('data-tab')

			// Update active button
			buttons.forEach((b) => {
				b.classList.remove('bg-foreground', 'text-background')
				b.classList.add('text-muted-foreground', 'hover:bg-muted', 'hover:text-foreground')
			})
			btn.classList.add('bg-foreground', 'text-background')
			btn.classList.remove('text-muted-foreground', 'hover:bg-muted', 'hover:text-foreground')

			// Swap panel
			panels.forEach((p) => {
				p.classList.add('hidden')
				p.classList.remove('animate-fade-in')
			})
			const target = document.getElementById(`panel-${tab}`)
			if (target) {
				target.classList.remove('hidden')
				void target.offsetWidth
				target.classList.add('animate-fade-in')
			}

			// Collapse hero for large sections, expand for small ones
			const collapseTabs = ['experience', 'projects']
			if (collapseTabs.includes(tab!)) {
				collapseHero()
				// Scroll to top after collapse so content starts right below sticky header
				hero.addEventListener(
					'transitionend',
					(e) => {
						if (e.propertyName === 'height') {
							window.scrollTo({ top: 0, behavior: 'smooth' })
						}
					},
					{ once: true }
				)
			} else {
				expandHero()
				window.scrollTo({ top: 0, behavior: 'smooth' })
			}
		})
	})

	// Reveal hero when user scrolls back to the very top
	window.addEventListener(
		'scroll',
		() => {
			if (window.scrollY === 0 && isCollapsed) {
				expandHero()
			}
		},
		{ passive: true }
	)
</script>
