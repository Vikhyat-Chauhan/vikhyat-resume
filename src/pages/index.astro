---
import PageLayout from '../layouts/BaseLayout.astro'

interface Project {
	num: string
	title: string
	tagline: string
	description: string
	stack: string[]
	metrics: { label: string; value: string }[]
	links: { label: string; href: string; primary?: boolean }[]
}

const projects: Project[] = [
	{
		num: '01',
		title: 'Medical Imaging Pipeline',
		tagline: 'MRI report generation, TensorRT-accelerated',
		description:
			'MedCLIP-based report generation system fusing MRI scan sequences with patient history, deployed on FDA-regulated hardware at GE HealthCare. Real-time Transformer segmentation accelerated via TensorRT/CUDA.',
		stack: ['PyTorch', 'TensorRT', 'CUDA/C++', 'MedCLIP', 'Kubernetes'],
		metrics: [
			{ label: 'Accuracy vs. SOTA', value: '+6.5%' },
			{ label: 'Throughput', value: '+20%' },
			{ label: 'Runtime', value: '−80%' }
		],
		links: [
			{ label: 'Case study', href: '/chat?q=Tell+me+about+the+MRI+report+generation+system', primary: true }
		]
	},
	{
		num: '02',
		title: 'ProfessionalRAG',
		tagline: 'Production RAG pipeline — Claude + Pinecone + reranking',
		description:
			'Two-stage retrieval (BGE embeddings + cross-encoder reranking), Claude-powered grounded generation, full observability. Per-query cost tracking, SHA-256 cache, LLM-as-judge eval. Powers the chat on this site.',
		stack: ['Python', 'FastAPI', 'Pinecone', 'Claude', 'Cloud Run'],
		metrics: [
			{ label: 'p50 latency', value: '~1.4s' },
			{ label: 'Eval coverage', value: '100%' },
			{ label: 'Cost/query', value: '<$0.01' }
		],
		links: [
			{ label: 'Live demo', href: '/chat', primary: true },
			{ label: 'GitHub', href: 'https://github.com/Vikhyat-Chauhan/ProfessionalRAG' }
		]
	},
	{
		num: '03',
		title: 'Fine-Tuned LLM + Multi-Agent RAG',
		tagline: 'LangGraph + Llama 3 for grammar-constrained codegen',
		description:
			'Multi-agent system generating SDF XML simulation environments under strict grammar constraints. Automated 100+ Gazebo scenes and eliminated ~40 hours/week of manual authoring.',
		stack: ['LangGraph', 'Llama 3', 'LoRA/QLoRA', 'HuggingFace', 'Python'],
		metrics: [
			{ label: 'Scenes generated', value: '100+' },
			{ label: 'Manual hrs saved', value: '40/wk' },
			{ label: 'Grammar valid', value: '100%' }
		],
		links: [
			{ label: 'Write-up', href: '/chat?q=Tell+me+about+the+multi-agent+SDF+generation+system', primary: true }
		]
	},
	{
		num: '04',
		title: 'Conflict Architecture — Thesis',
		tagline: 'Deadline-aware autonomous UAV navigation',
		description:
			'Multi-strategy selector arbitrating among three parallel execution engines (8/25/90 ms) based on event urgency. Validated across 1000+ simulated scenarios in ROS 2 / Gazebo. NSF-funded.',
		stack: ['Python', 'ROS 2', 'Gazebo', 'MoE', 'LangGraph'],
		metrics: [
			{ label: 'Mission latency', value: '−13%' },
			{ label: 'Energy use', value: '−13%' },
			{ label: 'Scenarios', value: '1000+' }
		],
		links: [
			{ label: 'Thesis page', href: '/ConflictArchitecture', primary: true },
			{ label: 'GitHub', href: 'https://github.com/Vikhyat-Chauhan/Hydra' }
		]
	}
]

const experience = [
	{
		company: 'Virginia Tech',
		role: 'Graduate AI/ML Researcher — NSF-funded',
		date: '2024 — 2026',
		bullets: [
			'Built a full UAV autonomy stack in ROS 2 / Gazebo validating the Conflict Architecture framework.',
			'Shipped a deadline-aware MoE planner with hardware-aware arbitration; cut mission latency and energy 13%.',
			'Architected LangGraph + Llama 3 multi-agent system for grammar-constrained SDF generation.'
		]
	},
	{
		company: 'GE HealthCare',
		role: 'Software Engineer II',
		date: '2022 — 2024',
		bullets: [
			'Led migration from C++ monolith to Java/Spring Boot on Kubernetes — runtime down 80%.',
			'Built MedCLIP-based MRI report generation; outperformed SOTA by 6.5% on clinical datasets.',
			'TensorRT/CUDA optimization of Transformer segmentation — throughput +20% on FDA-regulated hardware.'
		]
	},
	{
		company: 'TNM Electronics',
		role: 'Founding Software Engineer',
		date: '2021 — 2022',
		bullets: [
			'Built AWS microservice backend (EC2, Lambda, RabbitMQ, MQTT) from zero — 1000+ devices, 99.9% uptime.',
			'Patented master-slave microcontroller comms scheme — cut BOM cost 90%.'
		]
	}
]

const writing = [
	{
		title: 'Building production RAG: cost, latency, and eval lessons',
		href: 'https://www.linkedin.com/in/vikhyat-chauhan-183723169/',
		date: 'Coming soon'
	},
	{
		title: 'Conflict Architecture: rethinking real-time autonomy',
		href: 'https://www.linkedin.com/in/vikhyat-chauhan-183723169/',
		date: 'Coming soon'
	},
	{
		title: 'TensorRT in clinical software — what changes',
		href: 'https://www.linkedin.com/in/vikhyat-chauhan-183723169/',
		date: 'Coming soon'
	}
]
---

<PageLayout meta={{ title: 'Vikhyat Chauhan — AI/ML Engineer' }}>
	<!-- ─── HERO ─────────────────────────────────────────────────────── -->
	<section class='animate-fade-in mb-24 grid gap-8 sm:gap-12'>
		<div class='flex items-center gap-x-3'>
			<span class='inline-flex items-center gap-x-2 border border-border bg-card px-2.5 py-1 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-foreground'>
				<span class='h-1.5 w-1.5 rounded-full bg-accent'></span>
				US Work Authorized
			</span>
			<span class='font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-foreground'>
				Open to AI/ML roles · Spring 2026
			</span>
		</div>

		<div class='grid gap-y-6'>
			<h1 class='text-[clamp(2.2rem,6vw,4.25rem)] font-bold leading-[1.02] tracking-tight'>
				Vikhyat&nbsp;Chauhan
				<span class='block font-normal text-muted-foreground'>AI/ML Engineer</span>
			</h1>
			<p class='max-w-2xl text-lg leading-relaxed text-foreground/85 sm:text-xl'>
				I build production AI systems — from TensorRT inference pipelines on FDA-regulated
				hardware to retrieval-augmented LLM apps and autonomous UAV navigation.
			</p>
		</div>

		<div class='flex flex-wrap gap-3'>
			<a
				href='/Vikhyat-Chauhan-Resume.pdf'
				download
				class='inline-flex items-center gap-x-2 border border-foreground bg-foreground px-5 py-2.5 font-mono text-[0.7rem] uppercase tracking-[0.18em] text-background transition-colors hover:border-accent hover:bg-accent hover:text-accent-foreground'
			>
				Download Résumé ↓
			</a>
			<a
				href='https://github.com/Vikhyat-Chauhan'
				target='_blank'
				rel='noopener noreferrer'
				class='inline-flex items-center gap-x-2 border border-border px-5 py-2.5 font-mono text-[0.7rem] uppercase tracking-[0.18em] text-foreground transition-colors hover:border-foreground'
			>
				GitHub ↗
			</a>
			<a
				href='https://www.linkedin.com/in/vikhyat-chauhan-183723169/'
				target='_blank'
				rel='noopener noreferrer'
				class='inline-flex items-center gap-x-2 border border-border px-5 py-2.5 font-mono text-[0.7rem] uppercase tracking-[0.18em] text-foreground transition-colors hover:border-foreground'
			>
				LinkedIn ↗
			</a>
			<a
				href='/chat'
				class='inline-flex items-center gap-x-2 border border-accent px-5 py-2.5 font-mono text-[0.7rem] uppercase tracking-[0.18em] text-accent transition-colors hover:bg-accent hover:text-accent-foreground'
			>
				Ask my RAG →
			</a>
		</div>
	</section>

	<!-- ─── PROJECTS ─────────────────────────────────────────────────── -->
	<section id='projects' class='mb-24'>
		<div class='mb-10 flex items-baseline justify-between border-b border-border pb-3'>
			<h2 class='font-mono text-[0.7rem] uppercase tracking-[0.22em] text-muted-foreground'>
				/ Selected Work
			</h2>
			<span class='font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-foreground'>
				04 projects
			</span>
		</div>

		<div class='grid gap-px bg-border sm:grid-cols-2'>
			{projects.map((p) => (
				<article class='group flex flex-col gap-y-5 bg-background p-6 transition-colors hover:bg-card sm:p-8'>
					<div class='flex items-start justify-between gap-x-4'>
						<span class='font-mono text-[0.7rem] tracking-[0.18em] text-accent'>{p.num}</span>
						<div class='flex flex-wrap items-center justify-end gap-1'>
							{p.stack.map((s) => (
								<span class='border border-border px-1.5 py-0.5 font-mono text-[0.6rem] uppercase tracking-wider text-muted-foreground'>
									{s}
								</span>
							))}
						</div>
					</div>

					<div class='flex flex-col gap-y-2'>
						<h3 class='text-2xl font-semibold leading-tight tracking-tight'>{p.title}</h3>
						<p class='font-mono text-[0.75rem] uppercase tracking-wider text-muted-foreground'>
							{p.tagline}
						</p>
					</div>

					<p class='text-sm leading-relaxed text-foreground/80'>{p.description}</p>

					<dl class='mt-auto grid grid-cols-3 gap-x-3 border-t border-border pt-4'>
						{p.metrics.map((m) => (
							<div class='flex flex-col'>
								<dt class='font-mono text-[0.6rem] uppercase tracking-wider text-muted-foreground'>
									{m.label}
								</dt>
								<dd class='font-mono text-base font-semibold text-foreground'>{m.value}</dd>
							</div>
						))}
					</dl>

					<div class='flex flex-wrap gap-2'>
						{p.links.map((l) => (
							<a
								href={l.href}
								target={l.href.startsWith('http') ? '_blank' : undefined}
								rel={l.href.startsWith('http') ? 'noopener noreferrer' : undefined}
								class:list={[
									'inline-flex items-center gap-x-1.5 px-3 py-1.5 font-mono text-[0.65rem] uppercase tracking-[0.15em] transition-colors',
									l.primary
										? 'border border-foreground bg-foreground text-background hover:border-accent hover:bg-accent hover:text-accent-foreground'
										: 'border border-border text-foreground hover:border-foreground'
								]}
							>
								{l.label}
								<span>{l.href.startsWith('http') ? '↗' : '→'}</span>
							</a>
						))}
					</div>
				</article>
			))}
		</div>
	</section>

	<!-- ─── EXPERIENCE ───────────────────────────────────────────────── -->
	<section id='experience' class='mb-24'>
		<div class='mb-10 flex items-baseline justify-between border-b border-border pb-3'>
			<h2 class='font-mono text-[0.7rem] uppercase tracking-[0.22em] text-muted-foreground'>
				/ Experience
			</h2>
			<a href='/Vikhyat-Chauhan-Resume.pdf' download class='font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-foreground transition-colors hover:text-accent'>
				Full résumé ↓
			</a>
		</div>

		<ol class='flex flex-col'>
			{experience.map((e, i) => (
				<li class:list={['grid gap-y-3 py-6 sm:grid-cols-[10rem_1fr] sm:gap-x-8 sm:py-8', i !== 0 && 'border-t border-border']}>
					<div class='flex flex-col'>
						<span class='font-mono text-[0.7rem] uppercase tracking-[0.18em] text-muted-foreground'>
							{e.date}
						</span>
					</div>
					<div class='flex flex-col gap-y-3'>
						<div class='flex flex-col gap-y-0.5'>
							<h3 class='text-xl font-semibold tracking-tight'>{e.company}</h3>
							<p class='text-sm text-muted-foreground'>{e.role}</p>
						</div>
						<ul class='flex flex-col gap-y-1.5 text-sm leading-relaxed text-foreground/80'>
							{e.bullets.map((b) => (
								<li class='flex gap-x-3'>
									<span class='mt-2 h-px w-3 flex-shrink-0 bg-accent'></span>
									<span>{b}</span>
								</li>
							))}
						</ul>
					</div>
				</li>
			))}
		</ol>
	</section>

	<!-- ─── WRITING ──────────────────────────────────────────────────── -->
	<section id='writing' class='mb-24'>
		<div class='mb-10 flex items-baseline justify-between border-b border-border pb-3'>
			<h2 class='font-mono text-[0.7rem] uppercase tracking-[0.22em] text-muted-foreground'>
				/ Writing
			</h2>
			<a href='https://www.linkedin.com/in/vikhyat-chauhan-183723169/' target='_blank' rel='noopener noreferrer' class='font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-foreground transition-colors hover:text-accent'>
				All on LinkedIn ↗
			</a>
		</div>

		<ul class='flex flex-col'>
			{writing.map((w, i) => (
				<li class:list={[i !== 0 && 'border-t border-border']}>
					<a
						href={w.href}
						target='_blank'
						rel='noopener noreferrer'
						class='group flex flex-col gap-y-1 py-5 transition-colors hover:text-accent sm:flex-row sm:items-center sm:justify-between sm:gap-x-8'
					>
						<span class='text-base font-medium tracking-tight sm:text-lg'>{w.title}</span>
						<span class='font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-foreground group-hover:text-accent'>
							{w.date} ↗
						</span>
					</a>
				</li>
			))}
		</ul>
	</section>

	<!-- ─── CONTACT ──────────────────────────────────────────────────── -->
	<section id='contact'>
		<div class='mb-10 border-b border-border pb-3'>
			<h2 class='font-mono text-[0.7rem] uppercase tracking-[0.22em] text-muted-foreground'>
				/ Contact
			</h2>
		</div>
		<div class='grid gap-y-2 sm:grid-cols-2 sm:gap-y-0'>
			<a href='mailto:vikhyatchauhan@vt.edu' class='group flex items-baseline gap-x-3 py-2'>
				<span class='font-mono text-[0.7rem] uppercase tracking-[0.18em] text-muted-foreground'>Email</span>
				<span class='text-base tracking-tight transition-colors group-hover:text-accent'>vikhyatchauhan@vt.edu</span>
			</a>
			<a href='https://www.linkedin.com/in/vikhyat-chauhan-183723169/' target='_blank' rel='noopener noreferrer' class='group flex items-baseline gap-x-3 py-2'>
				<span class='font-mono text-[0.7rem] uppercase tracking-[0.18em] text-muted-foreground'>LinkedIn</span>
				<span class='text-base tracking-tight transition-colors group-hover:text-accent'>vikhyat-chauhan ↗</span>
			</a>
		</div>
	</section>
</PageLayout>
