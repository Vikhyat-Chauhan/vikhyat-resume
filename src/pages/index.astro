---
import Card from '../components/Card.astro'
import Label from '../components/Label.astro'
import ProjectCard from '../components/ProjectCard.astro'
import Section from '../components/Section.astro'
import SkillLayout from '../components/SkillLayout.astro'
import PageLayout from '../layouts/BaseLayout.astro'

import { Image } from 'astro:assets'
import astro from '../assets/Vikhyat-Image.png'

const languages = ['C++', 'Java', 'Python', 'TypeScript', 'SQL']
const aiLlm = [
	'RAG',
	'Agentic AI',
	'Fine-Tuning (LoRA/QLoRA)',
	'Prompt Engineering',
	'Embeddings',
	'LangChain',
	'LangGraph'
]
const ml = ['PyTorch', 'TensorFlow/TFX', 'TensorRT', 'scikit-learn']
const cloudInfra = [
	'AWS (EC2, Lambda, S3, EKS)',
	'GCP (GKE)',
	'Kubernetes',
	'Docker',
	'Kafka',
	'MongoDB',
	'Microservices',
	'REST API',
	'OAuth 2.0'
]
const systemsTools = [
	'ROS 2',
	'Claude Code',
	'Prometheus',
	'Grafana',
	'Jenkins',
	'SonarQube',
	'Git',
	'Perforce Helix',
	'SpringBoot',
	'Linux'
]
---

<PageLayout meta={{ title: 'Vikhyat Chauhan' }}>
	<div class='flex w-full flex-col gap-y-10'>
		<section class='flex flex-col items-center gap-y-7'>
			<Image
				src={astro}
				alt='profile photo'
				class='h-28 w-auto rounded-full bg-[#FFBE98] p-2'
				loading='eager'
			/>

			<div class='flex flex-col items-center gap-y-4'>
				<div class='flex flex-col items-center gap-1'>
					<h1 class='text-3xl font-bold'>Vikhyat Chauhan</h1>
					<a href='mailto:vikhyatchauhan@vt.edu' class='text-muted-foreground'>
						vikhyatchauhan@vt.edu
					</a>
				</div>
				<div class='flex flex-row flex-wrap justify-center gap-3'>
					<a
						href='https://www.linkedin.com/in/vikhyat-chauhan-183723169/'
						class='flex flex-row items-center gap-x-3 rounded-3xl border border-input px-4 py-2 text-sm shadow-sm transition-all hover:shadow-md'
					>
						<span class='relative flex items-center justify-center'>
							<span
								class='absolute inline-flex h-2 w-2 animate-ping rounded-full border border-green-400 bg-green-400 opacity-75'
							></span>
							<span class='relative inline-flex h-2 w-2 rounded-full bg-green-400'></span>
						</span>

						<p class='font-medium'>Contact Me</p>
					</a>
					<a
						href='/chat'
						class='flex flex-row items-center gap-x-3 rounded-3xl border border-input px-4 py-2 text-sm shadow-sm transition-all hover:shadow-md'
					>
						<span class='relative flex items-center justify-center'>
							<span
								class='absolute inline-flex h-2 w-2 animate-ping rounded-full border border-purple-400 bg-purple-400 opacity-75'
							></span>
							<span class='relative inline-flex h-2 w-2 rounded-full bg-purple-400'></span>
						</span>

						<p class='font-medium'>Chat with my Assistant</p>
					</a>
				</div>
				<div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
					<Label title='Graduate Research Assistant'>
						<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-5 w-5' slot='icon'
							><path
								fill='currentColor'
								d='M4.615 20q-.69 0-1.152-.462Q3 19.075 3 18.385v-9.77q0-.69.463-1.152Q3.925 7 4.615 7H9V5.615q0-.69.463-1.152Q9.925 4 10.615 4h2.77q.69 0 1.153.463q.462.462.462 1.152V7h4.385q.69 0 1.152.463q.463.462.463 1.152v9.77q0 .69-.462 1.152q-.463.463-1.153.463zm0-1h14.77q.23 0 .423-.192q.192-.193.192-.423v-9.77q0-.23-.192-.423Q19.615 8 19.385 8H4.615q-.23 0-.423.192Q4 8.385 4 8.615v9.77q0 .23.192.423q.193.192.423.192M10 7h4V5.615q0-.23-.192-.423Q13.615 5 13.385 5h-2.77q-.23 0-.423.192q-.192.193-.192.423zM4 19V8z'
							></path></svg
						>
					</Label>
					<Label title='Virginia, USA'>
						<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-5 w-5' slot='icon'
							><path
								fill='currentColor'
								d='M12.003 11.73q.668 0 1.14-.475q.472-.475.472-1.143t-.475-1.14q-.476-.472-1.143-.472t-1.14.476q-.472.475-.472 1.143t.475 1.14q.476.472 1.143.472M12 19.677q2.82-2.454 4.458-4.991q1.638-2.538 1.638-4.39q0-2.744-1.737-4.53T12 3.981q-2.621 0-4.359 1.785t-1.737 4.53q0 1.852 1.638 4.39q1.639 2.537 4.458 4.99m0 1.343q-3.525-3.117-5.31-5.814q-1.786-2.697-1.786-4.909q0-3.173 2.066-5.234Q9.037 3 12 3t5.03 2.062q2.066 2.061 2.066 5.234q0 2.212-1.785 4.909q-1.786 2.697-5.311 5.814m0-10.904'
							></path></svg
						>
					</Label>
					<Label
						title='Connect on Linkedin'
						as='a'
						href='https://www.linkedin.com/in/vikhyat-chauhan-183723169/'
						target='_blank'
					>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							viewBox='0 0 16 16'
							slot='icon'
							class='h-5 w-5 text-foreground/75'
							><path
								fill='currentColor'
								d='M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248c-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586c.173-.431.568-.878 1.232-.878c.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252c-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z'
							></path></svg
						>
					</Label>
				</div>
			</div>
		</section>

		<Section title='About'>
			<p class='text-muted-foreground'>
				I’m Vikhyat—a builder at heart who loves turning ideas into reliable products. My recent
				work: an NSF-backed UAV stack that cut deadline misses by 80% and reduced safety violations
				by 23%—without slowing down. Earlier, at GE Healthcare, I helped modernize real-time imaging
				platforms. I care about clean, well-documented code, meaningful metrics, and tools that help
				teams move faster. When I’m not coding, I’m probably meal-prepping a new vegan recipe or
				sketching the next idea. If you’re building at the edge of autonomy and AI, let’s talk.
			</p>
		</Section>
		<Section title='Experience'>
			<Card
				heading='Virginia Polytechnic Institute and State University'
				subheading='Graduate AI/ML Researcher — NSF-Funded'
				date='2024 - Present'
				location='Blacksburg, VA'
			>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>
						Shipped a production RAG system (sentence-transformers/all-MiniLM-L6-v2, ChromaDB,
						LangChain) over a 300+ page technical corpus — full pipeline from PDF ingestion and
						recursive semantic chunking through vector retrieval and LLM answer synthesis, serving
						sub-500ms query latency on a live public interface.
					</li>
					<li>
						Built LangGraph + Llama 3 multi-agent workflow for grammar-constrained SDF XML
						generation — produced 100+ simulation environments, eliminated 40 hrs/week of manual
						authoring.
					</li>
					<li>
						Engineered a deadline-aware MoE planner for UAV navigation (ROS 2/Gazebo) with
						hardware-aware arbitration across three heterogeneous TPUs — 13% lower mission latency,
						and 13% lower compute energy vs. baseline.
					</li>
				</ul>
			</Card>
			<Card
				heading='GE HealthCare'
				subheading='Software Engineer II'
				date='2022 - 2024'
				location='Milwaukee, WI'
			>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>
						Spearheaded software development by migration of a legacy C++ monolith MRI Application
						to Kubernetes-based microservices using Java and Spring Boot, owning the technical
						architecture — reducing runtime by 80%.
					</li>
					<li>
						Pioneered end-to-end TensorRT optimization of Transformer models (C++, Python, CUDA) —
						increasing real-time MRI segmentation throughput 20% and directly improving scanner
						responsiveness.
					</li>
					<li>
						Developed a multimodal MRI report generation system (cross-attention transformer,
						MedCLIP, PyTorch, TensorRT) fusing longitudinal scan sequences with patient history —
						outperformed SOTA by up to 6.5% across three clinical datasets; containerized via
						Docker/Kubernetes for FDA-regulated deployment.
					</li>
					<li>
						Introduced automated quality gates across release cycles — designing CI/CD pipelines
						(Docker, Jenkins, SonarQube) that reduced defects 60%, coordinating implementation
						across architecture, QA, and product.
					</li>
					<li>
						Sustained zero critical patient-safety incidents across all releases by leading
						cross-functional root-cause analysis.
					</li>
				</ul>
			</Card>
			<Card
				heading='TNM Electronics'
				subheading='Founding Software Engineer'
				date='2021 - 2022'
				location='Delhi, India'
			>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>
						Owned the full platform from day one — architected an AWS-backed microservice backend
						(EC2, Lambda, RabbitMQ, MongoDB, MQTT broker), scaling from 0 to 1000+ devices —
						sustaining 99.9% uptime.
					</li>
					<li>
						Reduced field bug reports 72% vs. prior manual integration method by designing a
						structured hardware-software validation workflow as the company's sole engineer.
					</li>
					<li>
						Conceived and patented a master-slave microcontroller communication system for home
						automation — cutting final product BOM cost 90%.
					</li>
				</ul>
			</Card>
			<Card
				heading='Mahindra Susten'
				subheading='Research Intern'
				date='Jun 2018 - Mar 2020'
				location='Maharashtra, IN'
	>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>
						Built a Linux-based autonomous quadcopter controller (MAVLink + advanced control) and
						integrated it into Mahindra Susten’s solar ops—automating routine inspection flights and
						cutting manual intervention across sites.
					</li>
					<li>
						Shipped an ML-driven thermal fault monitoring + end-to-end drone inspection pipeline
						that automated detection and reporting, delivering a 35% reduction in labor costs and
						faster issue triage.
					</li>
				</ul>
			</Card>
			<Card
				heading='Universal Robots'
				subheading='Research Intern'
				date='Jun 2018 - Mar 2020'
				location='Maharashtra, IN'
	>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>
						Deployed Universal Robots cobots across multiple manufacturing lines—designed safe
						workflows, trained operators, and optimized cell layouts—boosting throughput and
						reducing changeover time while meeting safety standards.
					</li>
					<li>
						Built production-grade automation with URCaps and custom scripts (pick-and-place,
						machine tending, QA), creating maintainable routines that cut manual variability and
						unplanned downtime.
					</li>
				</ul>
			</Card>
		</Section>

		<Section title='Skills'>
			<SkillLayout title='Languages' skills={languages} />
			<SkillLayout title='AI & LLM' skills={aiLlm} />
			<SkillLayout title='ML' skills={ml} />
			<SkillLayout title='Cloud & Infra' skills={cloudInfra} />
			<SkillLayout title='Systems & Tools' skills={systemsTools} />
		</Section>

		<Section title='Education'>
			<Card
				heading='Virginia Polytechnic Institute and State University'
				subheading='Master of Science in Computer Engineering with Thesis; GPA: 4.00'
				date='Aug 2024 – May 2026'
				location='Blacksburg, VA'
				/>
			<Card
				heading='College of Engineering Roorkee, Uttarakhand Technical University'
				subheading='Bachelor of Engineering in Electrical and Electronics; 77% (First Division)'
				date='Jul 2016 - Dec 2020'
				location='Uttarakhand, IN'
				/>
		</Section>

		<Section title='Projects'>
			<div class='grid grid-cols-1 gap-3 md:grid-cols-2'>
				<ProjectCard
					href='https://github.com/Vikhyat-Chauhan/Hydra'
					heading='Hydra — Master&#39;s Thesis'
					subheading='Deadline-aware autonomous UAV navigation system with TROOP — a multi-strategy selector that dynamically chooses among three parallel execution engines (8ms failsafe, 25ms balanced, 90ms high-quality) based on event urgency. Built in Python/ROS 2/Gazebo with realistic octocopter physics, procedural arena generation, and LiDAR-based navigation; validated across 1000+ simulated scenarios.'
					altText='Hydra'
					class='w-full'
				/>
				<ProjectCard
					href='https://github.com/Vikhyat-Chauhan/ProfessionalRAG'
					heading='ProfessionalRAG'
					subheading='Engineered a production-ready RAG system with two-stage retrieval (BGE embeddings + cross-encoder reranking), Claude-powered grounded generation, and full observability — deployed on Google Cloud Run with per-query cost tracking, SHA-256 caching, and automated answer quality scoring via LLM-as-judge evaluation.'
					altText='ProfessionalRAG'
					class='w-full'
				/>
				<ProjectCard
					heading='SentinelML'
					subheading='Enabled reliable, scalable ML serving at production scale—meeting strict SLOs with p99 < 250 ms and safe, rapid releases via canary deploys with a Python auto-healer/automatic rollback. Built comprehensive observability (Prometheus/Grafana dashboards & alerts) and performance validation (k6 load tests).'
					altText='Example'
					class='w-full'
				/>
				<ProjectCard
					href='https://github.com/Vikhyat-Chauhan/BioelectronicsAiWesad'
					heading='BioelectronicsAiWesad'
					subheading='ML pipeline for stress detection from wearable biosensors — Conv1D autoencoders for unsupervised feature extraction + SVM classification, achieving 83.5% accuracy on three-class emotion classification from multimodal physiological signals (WESAD dataset, 15 subjects).'
					altText='BioelectronicsAiWesad'
					class='w-full'
				/>
				<ProjectCard
					href='https://github.com/Vikhyat-Chauhan/TNM_BACKEND_ICHI'
					heading='TNM Backend'
					subheading='Microservices-based IoT smart home platform (Node.js, Express, MongoDB, MQTT, RabbitMQ) with real-time bidirectional device control, scene automation, Alexa voice integration, and cascading offline detection — deployed via Docker Compose across 3 services.'
					altText='TNM Backend'
					class='w-full'
				/>
				<ProjectCard
					href='https://github.com/Vikhyat-Chauhan/SmartHomeApplication'
					heading='TNM Smart Home'
					subheading='Cross-platform Flutter IoT app with sub-second MQTT real-time device control, Auth0 OAuth2 authentication, QR-based hardware onboarding, and scene automation — built with BLoC state management across 125+ Dart files with glassmorphic UI/UX.'
					altText='TNM Smart Home'
					class='w-full'
				/>
				<ProjectCard
					href='https://github.com/Vikhyat-Chauhan/vikhyat-resume'
					heading='vikhyat-resume'
					subheading='This portfolio site — built with Astro, React, Tailwind CSS, and deployed on Netlify with SSR. Features a live AI chat assistant powered by ProfessionalRAG.'
					altText='vikhyat-resume'
					class='w-full'
				/>
				<ProjectCard
					href='https://iprsearch.ipindia.gov.in/PublicSearch/PublicationSearch/ApplicationStatus'
					heading='Patent: 202111060973 - Intellectual Property India'
					subheading='System and method for facilitating communication between slave and master microcontroller for home automation.'
					altText='Example'
					class='w-full'
				/>
			</div>
		</Section>

		<Section title='Certifications'>
			<Card
				heading='Google Cloud Professional ML Engineer'
				subheading='Upcoming'
				location='2026'
			/>
			<Card
				heading='Neural Networks and Deep Learning'
				subheading='DeepLearning.AI'
				location='98.46%'
			/>
			<Card
				heading='Advanced Machine Learning'
				subheading='Graduate Course, Virginia Tech'
				location='4.0 GPA'
			/>
			<Card
				heading='Brain Inspired Computer Architecture'
				subheading='Graduate Course, Virginia Tech'
				location='4.0 GPA'
			/>
			<Card
				heading='Advanced Natural Language Processing(CS685 S24)'
				subheading='UMass Amherst'
				location='4.0 GPA'
			/>
		</Section>
	</div>
</PageLayout>
