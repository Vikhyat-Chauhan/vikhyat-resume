---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('writing', (p) => !p.data.draft)).sort(
  (a, b) => +new Date(b.data.date) - +new Date(a.data.date),
);

// Group by year (desc), then by date (desc) inside each year.
const byYear = new Map<number, typeof posts>();
for (const p of posts) {
  const y = new Date(p.data.date).getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = Array.from(byYear.keys()).sort((a, b) => b - a);

const fmt = (d: Date) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

const tagColor = (tag: string) => {
  const t = tag.toLowerCase();
  if (t.includes('engineering')) return 'bg-sky-50 text-sky-700 ring-sky-200';
  if (t.includes('research')) return 'bg-violet-50 text-violet-700 ring-violet-200';
  if (t.includes('note') || t.includes('thought')) return 'bg-orange-50 text-orange-700 ring-orange-200';
  return 'bg-zinc-100 text-zinc-700 ring-zinc-200';
};
---

<Layout title="Blog — Vikhyat Chauhan">
  <header class="sticky top-0 z-50 border-b border-zinc-200/70 bg-gradient-to-r from-orange-50/80 via-sky-50/70 via-50% to-violet-50/80 backdrop-blur">
    <nav class="mx-auto flex max-w-3xl items-center justify-between gap-3 px-4 py-4 sm:px-6">
      <a href="/" class="text-sm font-semibold tracking-tight text-zinc-900 hover:text-black">
        ← Vikhyat Chauhan
      </a>
      <div class="hidden gap-7 text-sm text-zinc-600 sm:flex">
        <a href="/#experience" class="transition hover:text-zinc-900">Experience</a>
        <a href="/#projects" class="transition hover:text-zinc-900">Projects</a>
        <a href="/blog" class="text-zinc-900">Blog</a>
        <a href="/personal" class="transition hover:text-zinc-900">Personal</a>
        <a href="/#contact" class="transition hover:text-zinc-900">Contact</a>
      </div>
      <button
        id="mobile-nav-toggle"
        type="button"
        aria-label="Open menu"
        aria-controls="mobile-nav"
        aria-expanded="false"
        class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-zinc-300 bg-white text-zinc-700 transition hover:border-zinc-400 hover:text-zinc-900 sm:hidden"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </nav>
    <div id="mobile-nav" class="hidden border-t border-zinc-200/70 sm:hidden">
      <div class="mx-auto grid max-w-3xl gap-1 px-4 py-3 text-sm text-zinc-700">
        <a href="/#experience" class="rounded px-2 py-2 transition hover:bg-white/60 hover:text-zinc-900">Experience</a>
        <a href="/#projects" class="rounded px-2 py-2 transition hover:bg-white/60 hover:text-zinc-900">Projects</a>
        <a href="/blog" class="rounded px-2 py-2 text-zinc-900">Blog</a>
        <a href="/personal" class="rounded px-2 py-2 transition hover:bg-white/60 hover:text-zinc-900">Personal</a>
        <a href="/#contact" class="rounded px-2 py-2 transition hover:bg-white/60 hover:text-zinc-900">Contact</a>
      </div>
    </div>
  </header>

  <script>
    (() => {
      const btn = document.getElementById('mobile-nav-toggle');
      const menu = document.getElementById('mobile-nav');
      if (!btn || !menu) return;
      btn.addEventListener('click', () => {
        const hidden = menu.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(!hidden));
      });
    })();
  </script>

  <main class="mx-auto max-w-3xl px-4 pb-24 pt-12 sm:px-6 sm:pt-16">
    <section class="mb-14">
      <div class="text-xs uppercase tracking-[0.16em] text-orange-700">Writing</div>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-zinc-900 sm:text-4xl">Blog</h1>
      <p class="mt-3 max-w-2xl text-[15px] leading-relaxed text-zinc-600">
        Long-form posts on the things I'm building and the papers I'm reading.
      </p>
    </section>

    {years.map((year) => (
      <section class="mb-14">
        <div class="mb-6 flex items-baseline gap-4">
          <h2 class="font-mono text-2xl font-semibold tracking-tight text-zinc-900">{year}</h2>
          <div class="h-px flex-1 bg-zinc-200"></div>
          <span class="font-mono text-[11px] uppercase tracking-wider text-zinc-500">
            {byYear.get(year)!.length} {byYear.get(year)!.length === 1 ? 'post' : 'posts'}
          </span>
        </div>

        <ol class="space-y-8">
          {byYear.get(year)!.map((p, i) => (
            <li class="grid gap-2 sm:grid-cols-[72px_1fr] sm:gap-6">
              <div class="font-mono text-xs uppercase tracking-wider text-zinc-500 sm:pt-1">
                {fmt(p.data.date)}
              </div>
              <div>
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                  <h3 class="text-lg font-semibold tracking-tight text-zinc-900">
                    <a href={`/blog/${p.id}`} class="hover:underline underline-offset-4">{p.data.title}</a>
                  </h3>
                  <span class={`inline-flex items-center rounded-full px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider ring-1 ring-inset ${tagColor(p.data.tag)}`}>
                    {p.data.tag}
                  </span>
                </div>
                <p class="mt-2 text-[15px] leading-relaxed text-zinc-600">{p.data.blurb}</p>
                {p.data.readingTime && (
                  <div class="mt-2 font-mono text-[11px] uppercase tracking-wider text-zinc-500">
                    {p.data.readingTime}
                  </div>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>
    ))}

    {posts.length === 0 && (
      <p class="text-sm text-zinc-500">No posts yet — check back soon.</p>
    )}

    <footer class="mt-20 border-t border-zinc-200 py-8 text-xs text-zinc-500">
      <div class="flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-center">
        <div>© {new Date().getFullYear()} Vikhyat Chauhan</div>
        <div class="font-mono">Astro · Tailwind · Netlify</div>
      </div>
    </footer>
  </main>
</Layout>
