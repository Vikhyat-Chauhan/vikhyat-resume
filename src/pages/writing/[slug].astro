---
import { getCollection, render } from 'astro:content';
import LongPost from '../../components/LongPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing', (p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, subtitle, date, readingTime } = post.data;

const dateLabel = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<LongPost title={title} subtitle={subtitle} date={dateLabel} readingTime={readingTime}>
  <Content />
</LongPost>
