---
import { cn } from '@/utils'
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

const {
	as: Tag = 'a',
	class: className,
	href,
	heading,
	subheading,
	imagePath,
	altText
} = Astro.props
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/*.{jpeg,jpg,png,gif}')
if (imagePath && !images[imagePath])
	throw new Error(`"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif}"`)

const isGitHub = href?.includes('github.com')
---

<Tag
	class={cn(
		className,
		'group flex flex-col rounded-xl border border-border/50 bg-card transition-all duration-300',
		href && 'hover:border-border hover:bg-card/80 hover:shadow-lg hover:shadow-white/[0.02]'
	)}
	href={href}
	target={href?.startsWith('http') ? '_blank' : undefined}
	rel={href?.startsWith('http') ? 'noopener noreferrer' : undefined}
>
	{
		imagePath && (
			<Image
				src={images[imagePath]()}
				alt={altText}
				class='h-48 w-full rounded-t-xl object-cover'
				loading='eager'
			/>
		)
	}
	<div class='flex flex-1 flex-col gap-y-2 px-5 py-4'>
		<div class='flex items-start justify-between gap-x-2'>
			<h1 class='text-base font-semibold tracking-tight'>
				{isGitHub && (
					<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' class='mb-0.5 mr-1.5 inline h-4 w-4 text-muted-foreground'>
						<path
							fill='currentColor'
							d='M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z'
						></path>
					</svg>
				)}
				{heading}
			</h1>
			{href && (
				<svg
					xmlns='http://www.w3.org/2000/svg'
					viewBox='0 0 24 24'
					class='mt-0.5 h-4 w-4 flex-shrink-0 text-muted-foreground transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-sage'
				>
					<path
						fill='currentColor'
						d='M5 21q-.825 0-1.412-.587T3 19V5q0-.825.588-1.412T5 3h7v2H5v14h14v-7h2v7q0 .825-.587 1.413T19 21zm4.7-5.3l-1.4-1.4L17.6 5H14V3h7v7h-2V6.4z'
					></path>
				</svg>
			)}
		</div>
		<p class='text-sm leading-relaxed text-muted-foreground'>{subheading}</p>
	</div>

	<slot />
</Tag>
