---

---

<header id='site-header' class='sticky top-0 z-20 mb-6 w-full pb-2'>
	<nav
		class='glass relative mx-auto flex w-full flex-col gap-y-2 rounded-2xl border border-border/50 px-4 py-2.5 sm:flex-row sm:items-center sm:gap-x-3 sm:gap-y-0'
		aria-label='global'
	>
		<!-- Section tabs — full width on mobile, flex on desktop -->
		<div id='tab-nav' class='hidden min-w-0 flex-1'>
			<div class='flex items-center gap-x-1 overflow-x-auto scrollbar-hide'>
				<button data-tab='about' class='tab-btn whitespace-nowrap rounded-md px-3 py-1.5 text-xs font-medium transition-all duration-200 bg-foreground text-background sm:text-sm'>About</button>
				<button data-tab='experience' class='tab-btn whitespace-nowrap rounded-md px-3 py-1.5 text-xs font-medium transition-all duration-200 text-muted-foreground hover:bg-muted hover:text-foreground sm:text-sm'>Experience</button>
				<button data-tab='projects' class='tab-btn whitespace-nowrap rounded-md px-3 py-1.5 text-xs font-medium transition-all duration-200 text-muted-foreground hover:bg-muted hover:text-foreground sm:text-sm'>Projects</button>
				<button data-tab='skills' class='tab-btn whitespace-nowrap rounded-md px-3 py-1.5 text-xs font-medium transition-all duration-200 text-muted-foreground hover:bg-muted hover:text-foreground sm:text-sm'>Skills</button>
				<button data-tab='education' class='tab-btn whitespace-nowrap rounded-md px-3 py-1.5 text-xs font-medium transition-all duration-200 text-muted-foreground hover:bg-muted hover:text-foreground sm:text-sm'>Education</button>
				<button data-tab='certifications' class='tab-btn whitespace-nowrap rounded-md px-3 py-1.5 text-xs font-medium transition-all duration-200 text-muted-foreground hover:bg-muted hover:text-foreground sm:text-sm'>Certifications</button>
			</div>
		</div>

		<!-- Divider — desktop only -->
		<div id='tab-divider' class='hidden h-5 w-px bg-border/50 max-sm:!hidden'></div>

		<!-- Action buttons -->
		<div class='flex flex-none items-center justify-center gap-x-1 sm:ml-auto'>
			<a
				href='https://github.com/Vikhyat-Chauhan'
				target='_blank'
				rel='noopener noreferrer'
				class='rounded-lg p-2 text-muted-foreground transition-all hover:bg-muted hover:text-foreground'
				aria-label='GitHub'
			>
				<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' class='h-4 w-4'>
					<path
						fill='currentColor'
						d='M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z'
					></path>
				</svg>
			</a>

			<a
				href='https://www.linkedin.com/in/vikhyat-chauhan-183723169/'
				target='_blank'
				rel='noopener noreferrer'
				class='rounded-lg p-2 text-muted-foreground transition-all hover:bg-muted hover:text-foreground'
				aria-label='LinkedIn'
			>
				<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' class='h-4 w-4'>
					<path
						fill='currentColor'
						d='M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248c-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586c.173-.431.568-.878 1.232-.878c.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252c-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z'
					></path>
				</svg>
			</a>

			<a
				href='mailto:vikhyatchauhan@vt.edu'
				class='rounded-lg p-2 text-muted-foreground transition-all hover:bg-muted hover:text-foreground'
				aria-label='Email'
			>
				<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-4 w-4'>
					<path
						fill='currentColor'
						d='M4 20q-.825 0-1.412-.587T2 18V6q0-.825.588-1.412T4 4h16q.825 0 1.413.588T22 6v12q0 .825-.587 1.413T20 20zm8-7l8-5V6l-8 5l-8-5v2z'
					></path>
				</svg>
			</a>

			<!-- AI Chat — robot icon -->
			<a
				href='/chat'
				class='rounded-lg p-2 text-muted-foreground transition-all hover:bg-muted hover:text-foreground'
				aria-label='AI Chat'
			>
				<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-4 w-4'>
					<path
						fill='currentColor'
						d='M17.753 14a2.25 2.25 0 0 1 2.25 2.25v.904A3.75 3.75 0 0 1 18.696 20c-1.565 1.344-3.806 2-6.696 2s-5.128-.656-6.69-2a3.75 3.75 0 0 1-1.307-2.846v-.904A2.25 2.25 0 0 1 6.253 14zM12 2a4 4 0 1 1 0 8a4 4 0 0 1 0-8'
					></path>
					<circle cx='9' cy='6' r='0.75' fill='currentColor'></circle>
					<circle cx='15' cy='6' r='0.75' fill='currentColor'></circle>
				</svg>
			</a>

			<a
				href='/Vikhyat-Chauhan-Resume.pdf'
				download
				class='rounded-lg bg-foreground px-3 py-1.5 text-xs font-medium text-background transition-all hover:bg-foreground/85 sm:text-[0.82rem]'
				aria-label='Download Resume'
			>
				Resume
			</a>

			<button
				id='toggleDarkMode'
				class='rounded-lg p-2 text-muted-foreground transition-all hover:bg-muted hover:text-foreground'
			>
				<span class='sr-only'>Dark Theme</span>
				<svg
					xmlns='http://www.w3.org/2000/svg'
					width='32'
					height='32'
					viewBox='0 0 24 24'
					class='h-4 w-4 rotate-0 scale-100 transition-all dark:hidden dark:-rotate-90 dark:scale-0'
					><path
						fill='currentColor'
						d='M12 15q1.25 0 2.125-.875T15 12q0-1.25-.875-2.125T12 9q-1.25 0-2.125.875T9 12q0 1.25.875 2.125T12 15m0 1q-1.671 0-2.836-1.164T8 12q0-1.671 1.164-2.836T12 8q1.671 0 2.836 1.164T16 12q0 1.671-1.164 2.836T12 16m-7-3.5H1.5v-1H5zm17.5 0H19v-1h3.5zM11.5 5V1.5h1V5zm0 17.5V19h1v3.5zM6.746 7.404l-2.16-2.098l.695-.744l2.111 2.134zM18.72 19.438l-2.117-2.14l.652-.702l2.16 2.098zM16.596 6.746l2.098-2.16l.744.695l-2.134 2.111zM4.562 18.72l2.14-2.117l.663.652l-2.078 2.179zM12 12'
					></path></svg
				>
				<svg
					xmlns='http://www.w3.org/2000/svg'
					width='32'
					height='32'
					viewBox='0 0 24 24'
					class='hidden h-4 w-4 rotate-90 scale-0 transition-all dark:block dark:rotate-0 dark:scale-100'
					><path
						fill='currentColor'
						d='M12.058 20q-3.334 0-5.667-2.333Q4.058 15.333 4.058 12q0-3.038 1.98-5.27Q8.02 4.5 10.942 4.097q.081 0 .159.006t.153.017q-.506.706-.801 1.57q-.295.865-.295 1.811q0 2.667 1.866 4.533q1.867 1.867 4.534 1.867q.952 0 1.813-.295q.862-.295 1.548-.801q.012.075.018.153q.005.078.005.158q-.384 2.923-2.615 4.904T12.057 20'
					></path></svg
				>
			</button>
		</div>
	</nav>
</header>

<style>
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
</style>

<script>
	function getCurrentTheme() {
		return localStorage.getItem('theme')
	}
	const toggleDarkModeButton = document.getElementById('toggleDarkMode')

	toggleDarkModeButton?.addEventListener('click', () => {
		const toggleDarkModeEvent = new CustomEvent('theme-change', {
			detail: { theme: getCurrentTheme() === 'light' ? 'dark' : 'light' }
		})
		document.dispatchEvent(toggleDarkModeEvent)
	})

	// Show tab nav + divider only on the index page
	const tabNav = document.getElementById('tab-nav')
	const tabDivider = document.getElementById('tab-divider')
	const hasTabPanels = document.querySelector('.tab-panel')
	if (tabNav && hasTabPanels) {
		tabNav.classList.remove('hidden')
		tabDivider?.classList.remove('hidden')
	}
</script>
