---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<div class="flex flex-col gap-1">
  <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">{title}</h2>
  {subtitle && <p class="text-sm text-zinc-500">{subtitle}</p>}
</div>
