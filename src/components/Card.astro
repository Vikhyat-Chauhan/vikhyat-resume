---
import { cn } from '@/utils'
import { Image } from 'astro:assets'

const { as: Tag = 'div', class: className, href, heading, subheading, date, location, logo } = Astro.props
---

<Tag
	class={cn(
		className,
		'group relative rounded-xl border border-border/50 bg-card px-5 py-4 transition-all duration-300',
		href && 'hover:border-border hover:bg-card/80 hover:shadow-lg hover:shadow-white/[0.02]'
	)}
	href={href}
>
	<div class='flex gap-x-4'>
		{logo && (
			<div class='flex-shrink-0 pt-0.5'>
				<Image
					src={logo}
					alt={`${heading} logo`}
					class='h-9 w-9 rounded-lg object-contain'
					width={36}
					height={36}
				/>
			</div>
		)}
		<div class='flex min-w-0 flex-1 flex-col gap-y-1.5'>
			<div class='flex flex-col gap-y-0.5'>
				<div class='flex w-full flex-col flex-wrap gap-y-0.5 md:flex-row md:items-center md:justify-between'>
					<h1 class='text-lg font-semibold tracking-tight'>{heading}</h1>
					{location && <span class='text-sm text-muted-foreground'>{location}</span>}
				</div>
				<div class='flex flex-col gap-y-0.5 sm:flex-row sm:items-center sm:gap-x-3'>
					<h2 class='font-medium text-sage'>{subheading}</h2>
					{date && (
						<span class='text-sm text-muted-foreground'>
							<span class='hidden sm:inline'>&middot;&nbsp;</span>{date}
						</span>
					)}
				</div>
			</div>
			<slot />
		</div>
	</div>
</Tag>
