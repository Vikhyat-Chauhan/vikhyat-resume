<script>
	;(function () {
		// ── Helper ───────────────────────────────────────────────────
		function track(payload: Record<string, unknown>) {
			const body = JSON.stringify(payload)
			if (navigator.sendBeacon) {
				navigator.sendBeacon('/api/track', body)
			} else {
				fetch('/api/track', { method: 'POST', body, keepalive: true })
			}
		}

		// ── Page visit (once per session) ────────────────────────────
		if (!sessionStorage.getItem('visit_tracked')) {
			sessionStorage.setItem('visit_tracked', '1')

			const params = new URLSearchParams(window.location.search)
			const referrer = document.referrer

			const payload: Record<string, unknown> = {
				event: 'pageview',
				page: window.location.pathname,
				referrer: referrer || 'direct',
				screen_width: window.screen.width,
				screen_height: window.screen.height,
				viewport_width: window.innerWidth,
				viewport_height: window.innerHeight,
				device_type:
					window.innerWidth < 768 ? 'mobile' : window.innerWidth < 1024 ? 'tablet' : 'desktop',
				language: navigator.language,
				theme: document.documentElement.classList.contains('dark') ? 'dark' : 'light'
			}

			for (const p of ['utm_source', 'utm_medium', 'utm_campaign', 'ref']) {
				const v = params.get(p)
				if (v) payload[p] = v
			}

			if (!payload.utm_source && !payload.ref && referrer) {
				try {
					payload.source = new URL(referrer).hostname
				} catch {
					/* ignore */
				}
			}

			track(payload)
		}

		// ── Tab clicks ───────────────────────────────────────────────
		document.querySelectorAll('.tab-btn').forEach((btn) => {
			btn.addEventListener('click', () => {
				const tab = btn.getAttribute('data-tab')
				if (tab) track({ event: 'tab_click', tab })
			})
		})

		// ── Resume download ──────────────────────────────────────────
		document.querySelectorAll('a[download]').forEach((link) => {
			link.addEventListener('click', () => {
				track({ event: 'resume_download' })
			})
		})

		// ── Outbound link clicks ─────────────────────────────────────
		document.addEventListener('click', (e) => {
			const link = (e.target as Element).closest('a[href]') as HTMLAnchorElement | null
			if (!link) return
			const href = link.getAttribute('href')
			if (!href || !href.startsWith('http')) return

			try {
				const url = new URL(href)
				if (url.hostname !== window.location.hostname) {
					track({ event: 'outbound_click', url: href, hostname: url.hostname })
				}
			} catch {
				/* ignore */
			}
		})

		// ── Time on site ─────────────────────────────────────────────
		const startTime = Date.now()
		window.addEventListener('beforeunload', () => {
			const seconds = Math.round((Date.now() - startTime) / 1000)
			if (seconds > 2) {
				track({ event: 'time_on_site', seconds, page: window.location.pathname })
			}
		})
	})()
</script>
