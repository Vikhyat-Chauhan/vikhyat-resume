---
import type { SiteMeta } from '@/types'

import BaseHead from '@/components/BaseHead.astro'
import Header from '@/components/layout/Header.astro'
import ThemeProvider from '@/components/ThemeProvider.astro'

import { siteConfig } from '@/site-config'

interface Props {
	meta: SiteMeta
}

const {
	meta: { description = siteConfig.description, ogImage, title }
} = Astro.props
---

<html lang={siteConfig.lang} class=''>
	<head>
		<BaseHead description={description} ogImage={ogImage} title={title} />
	</head>

	<body class='flex justify-center overflow-hidden bg-background'>
		<ThemeProvider />
		<div
			class='flex h-dvh w-screen max-w-[64rem] flex-col px-6 pt-8 pb-6 font-satoshi text-[0.92rem] leading-relaxed sm:px-10 lg:px-12'
		>
			<Header />
			<slot />
		</div>
		<script>
			;(function () {
				const key = 'visit_tracked'
				if (sessionStorage.getItem(key)) return
				sessionStorage.setItem(key, '1')

				const params = new URLSearchParams(window.location.search)
				const referrer = document.referrer

				const payload: Record<string, string> = {
					page: window.location.pathname,
					referrer: referrer || 'direct'
				}

				for (const p of ['utm_source', 'utm_medium', 'utm_campaign', 'ref']) {
					const v = params.get(p)
					if (v) payload[p] = v
				}

				if (!payload.utm_source && !payload.ref && referrer) {
					try {
						payload.source = new URL(referrer).hostname
					} catch {
						/* ignore malformed referrers */
					}
				}

				if (navigator.sendBeacon) {
					navigator.sendBeacon('/api/track', JSON.stringify(payload))
				} else {
					fetch('/api/track', {
						method: 'POST',
						body: JSON.stringify(payload),
						keepalive: true
					})
				}
			})()
		</script>
	</body>
</html>
